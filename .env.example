DB_PATH=/app/data/cashflow.db
SECRET_KEY=change-me-to-a-random-32-char-string
SESSION_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string
JWT_EXPIRE_DAYS=30
BASIC_AUTH_ENABLED=true
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://your-oidc-provider.com/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/oidc/callback
ALLOWED_ORIGINS=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000
TZ=Europe/Rome
DEVELOPMENT_MODE=true
# COOKIE_SECURE=false  # Set to false when serving over HTTP on a non-localhost hostname (e.g. Tailscale/LAN)
