# ── Runtime user (must match host data directory owner) ──────────────────
# Run: APP_UID=$(id -u) APP_GID=$(id -g) to get these values
APP_UID=1000
APP_GID=1000

# ── Database ──────────────────────────────────────────────────────────────
# Path inside the container. Do not change unless you know what you're doing.
DB_PATH=/app/data/cashflow.db

# ── Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED — never leave as default in production
SECRET_KEY=change-me-in-production

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED — never leave as default in production
SESSION_ENCRYPTION_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your production domain.
ALLOWED_ORIGINS=https://your-domain.com

# ── Timezone ──────────────────────────────────────────────────────────────
TZ=Europe/Rome
